# LycianWay — Environment Variables
# Copy this file:  cp .env.example .env
# Never commit .env to git!

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key for AI interpretation.
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Docker: Databases directory ───────────────────────────────────────────────
# Absolute path on the HOST machine where your databases live.
# This directory is mounted read-only at /databases inside the container.
#
# Expected layout:
#   $DATABASES_DIR/
#     kraken2_db/                                             (Kraken2 standard DB)
#     bact_databases_ALL/
#       checkm2_v2_20210323/
#         uniref100.KO.1.dmnd                                (CheckM2 DB)
#     checkv_db/                                             (CheckV DB, optional)
#     database_pharokka/                                     (Pharokka DB, optional)
#
DATABASES_DIR=/home/analysis/databases_all

# ── Optional overrides ────────────────────────────────────────────────────────
# Only set these if your database layout differs from the defaults above.
# KRAKEN2_DEFAULT_DB=/databases/kraken2_db
# CHECKM2_DB=/databases/bact_databases_ALL/checkm2_v2_20210323/uniref100.KO.1.dmnd
# CHECKV_DB=/databases/checkv_db

# ── Resource limits ────────────────────────────────────────────────────────────
# CPU_LIMIT=16
# MEM_LIMIT=32G

# ── Server port (default: 8000) ────────────────────────────────────────────────
# PORT=8000
